# ─────────────────────────────────────────────────────────────────────────────
# VMOrbit — Production Environment Variables
#
# Copy this file to .env.production and fill in all values.
# NEVER commit .env.production to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
APP_VERSION=1.0.0

# ── Database ──────────────────────────────────────────────────────────────────
DB_USER=vmorbit
DB_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
DB_NAME=vmorbit

# GORM / backend connection (overrides config.yaml via VMORBIT_ prefix)
VMORBIT_DATABASE_USER=vmorbit
VMORBIT_DATABASE_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
VMORBIT_DATABASE_DBNAME=vmorbit
VMORBIT_DATABASE_SSLMODE=disable
VMORBIT_DATABASE_MAX_OPEN_CONNS=50
VMORBIT_DATABASE_MAX_IDLE_CONNS=15
VMORBIT_DATABASE_CONN_MAX_LIFETIME=5m

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD
REDIS_MAX_MEMORY=512mb

VMORBIT_REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD
VMORBIT_REDIS_DB=0
VMORBIT_REDIS_POOL_SIZE=20

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
VMORBIT_JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_BASE64_64
VMORBIT_JWT_ACCESS_TOKEN_TTL=15m
VMORBIT_JWT_REFRESH_TOKEN_TTL=168h
VMORBIT_JWT_ISSUER=vmOrbit

# ── Server ────────────────────────────────────────────────────────────────────
VMORBIT_SERVER_PORT=8080
VMORBIT_SERVER_MODE=release
VMORBIT_SERVER_READ_TIMEOUT=15s
VMORBIT_SERVER_WRITE_TIMEOUT=15s
VMORBIT_SERVER_IDLE_TIMEOUT=60s
# Comma-separated allowed CORS origins (your production domain)
VMORBIT_SERVER_CORS_ORIGINS=https://vmorbit.example.com

# ── Encryption key for provider credentials (AES-256-GCM) ────────────────────
# Generate with: openssl rand -hex 32
VMORBIT_ENCRYPTION_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32

# ── Task Engine ───────────────────────────────────────────────────────────────
VMORBIT_TASK_ENGINE_WORKER_COUNT=10
VMORBIT_TASK_ENGINE_QUEUE_SIZE=1000
VMORBIT_TASK_ENGINE_MAX_RETRIES=3
VMORBIT_TASK_ENGINE_DEFAULT_TIMEOUT=10m

# ── Logging ───────────────────────────────────────────────────────────────────
VMORBIT_LOG_LEVEL=info
VMORBIT_LOG_FORMAT=json

# ── Metrics ───────────────────────────────────────────────────────────────────
VMORBIT_METRICS_ENABLED=true
VMORBIT_METRICS_PATH=/metrics

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://vmorbit.example.com

# ── Backup ────────────────────────────────────────────────────────────────────
BACKUP_RETENTION_DAYS=7
