# Place your TLS certificate files here:
#   fullchain.pem  — full certificate chain (cert + intermediates)
#   privkey.pem    — private key
#
# For Let's Encrypt: copy from /etc/letsencrypt/live/<domain>/
# For self-signed (dev/test only):
#   openssl req -x509 -nodes -days 365 -newkey rsa:2048 \
#     -keyout privkey.pem -out fullchain.pem \
#     -subj "/CN=vmorbit.example.com"
